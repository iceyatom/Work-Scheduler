// Prisma is the single source of truth for the application schema & migrations.
// Times are stored as integer "minutes from midnight" (e.g. 5:00 AM = 300,
// 12:30 AM next day = 1470). Day-of-week is 0 = Monday … 6 = Sunday so the
// per-day late-night cutoffs line up with their array index.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------------------------------------------------------------------------
// Accounts & sessions (multi-tenant auth). Each company logs in to its own
// account; all employees/schedules/changes are scoped to it.
// ---------------------------------------------------------------------------

model Account {
  id            String  @id @default(cuid())
  username      String  @unique // as entered (for display)
  usernameLower String  @unique // normalized for case-insensitive lookup/uniqueness
  passwordHash  String // scrypt salt:hash (never store plaintext)

  // Lockout after too many failed logins.
  failedAttempts Int       @default(0)
  lockedUntil    DateTime?

  employees        Employee[]
  schedules        Schedule[]
  personnelChanges PersonnelChange[]
  jobs             Job[]
  sessions         Session[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// One row per logged-in browser session; token lives in an httpOnly cookie.
model Session {
  id        String   @id @default(cuid())
  token     String   @unique
  account   Account  @relation(fields: [accountId], references: [id], onDelete: Cascade)
  accountId String
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([accountId])
}

// ---------------------------------------------------------------------------
// People & personnel inputs (spec §5)
// ---------------------------------------------------------------------------

enum EmploymentType {
  FULL_TIME
  PART_TIME
}

model Employee {
  id             String         @id @default(cuid())
  // Owning account. Nullable only to allow zero-downtime backfill of pre-auth
  // rows; application code always sets and filters by it.
  account        Account?       @relation(fields: [accountId], references: [id], onDelete: Cascade)
  accountId      String?
  name           String
  employmentType EmploymentType @default(PART_TIME)
  isManager      Boolean        @default(false) // can satisfy the manager-presence rule
  isGM           Boolean        @default(false) // general manager: 10.5h shift cap, usually hard-set
  isMinor        Boolean        @default(false) // school-night limits apply
  active         Boolean        @default(true)  // false once terminated / suspended

  // Priority-weighting input (spec §5.1). Hours flow to FT staff and higher
  // performers first.
  performance     Int   @default(3) // 1 (low) … 5 (high)

  // Optional weekly hour bounds used by the solver objective.
  minHoursPerWeek Int?
  maxHoursPerWeek Int?

  availability      Availability[]
  hardSets          HardSetAssignment[]
  assignments       Assignment[]
  personnelChanges  PersonnelChange[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([accountId])
}

// Recurring weekly windows the person can work (spec §5 "general availability").
model Availability {
  id         String   @id @default(cuid())
  employee   Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  employeeId String
  dayOfWeek  Int // 0 = Monday … 6 = Sunday
  startMin   Int // minutes from midnight
  endMin     Int

  @@index([employeeId])
}

// Manager-locked shift treated as a fixed constant by the solver (spec §5).
// weekStart == null  -> recurring template (applies every week)
// weekStart != null  -> one-week override for that specific week & day
model HardSetAssignment {
  id         String    @id @default(cuid())
  employee   Employee  @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  employeeId String
  dayOfWeek  Int
  startMin   Int
  endMin     Int
  weekStart  DateTime? @db.Date
  note       String?

  @@index([employeeId])
}

// ---------------------------------------------------------------------------
// Generated schedules (spec §7, §8)
// ---------------------------------------------------------------------------

enum ScheduleStatus {
  DRAFT
  PUBLISHED
}

enum GeneratedFrom {
  BLANK   // F-1: generated from a blank slate
  RESOLVE // F-2: produced by incremental re-solve of a prior schedule
}

model Schedule {
  id            String         @id @default(cuid())
  account       Account?       @relation(fields: [accountId], references: [id], onDelete: Cascade)
  accountId     String?
  name          String
  weekStart     DateTime       @db.Date // Monday of the scheduled week
  status        ScheduleStatus @default(DRAFT)
  generatedFrom GeneratedFrom  @default(BLANK)

  solverStatus   String? // OPTIMAL / FEASIBLE / INFEASIBLE / ...
  objectiveValue Float?
  solveMs        Int?

  // Gap report (unmet soft constraints) stored as JSONB (spec §7.6, §10).
  gaps Json?
  meta Json?

  assignments Assignment[]
  jobs        Job[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([accountId])
}

enum AssignmentSource {
  SOLVER
  MANUAL
  HARDSET
}

model Assignment {
  id         String   @id @default(cuid())
  schedule   Schedule @relation(fields: [scheduleId], references: [id], onDelete: Cascade)
  scheduleId String
  employee   Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  employeeId String

  dayOfWeek   Int
  startMin    Int
  endMin      Int
  // Start minutes of each unpaid 30-min lunch (one per 5h worked; empty if <=5h).
  breakStarts Int[] @default([])
  paidMinutes Int   // (endMin - startMin) minus the unpaid breaks

  locked Boolean          @default(false) // pinned (hard-set or manager-locked)
  source AssignmentSource @default(SOLVER)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([scheduleId])
  @@index([employeeId])
}

// ---------------------------------------------------------------------------
// Queued personnel changes for incremental re-solve (spec §6, F-2)
// ---------------------------------------------------------------------------

enum ChangeType {
  DAY_OFF
  TERMINATION
  SUSPENSION
  LEAVE_OF_ABSENCE
  AVAILABILITY_CHANGE
}

enum ChangeStatus {
  QUEUED
  APPLIED
  DISCARDED
}

model PersonnelChange {
  id         String       @id @default(cuid())
  account    Account?     @relation(fields: [accountId], references: [id], onDelete: Cascade)
  accountId  String?
  employee   Employee     @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  employeeId String
  type       ChangeType
  status     ChangeStatus @default(QUEUED)

  dayOfWeek Int? // for whole/partial day-off (null = all days / going forward)
  startMin  Int? // partial-day-off window, or new availability window start
  endMin    Int?
  note      String?

  // Structured details (e.g. list of new availability windows for AVAILABILITY_CHANGE).
  payload Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([employeeId])
  @@index([status])
  @@index([accountId])
}

// ---------------------------------------------------------------------------
// Async solve jobs. Locally these run synchronously; the model mirrors the
// SQS-backed async flow in the target architecture (spec §10).
// ---------------------------------------------------------------------------

enum JobType {
  GENERATE
  RESOLVE
}

enum JobStatus {
  QUEUED
  RUNNING
  DONE
  FAILED
}

model Job {
  id         String    @id @default(cuid())
  account    Account?  @relation(fields: [accountId], references: [id], onDelete: Cascade)
  accountId  String?
  type       JobType
  status     JobStatus @default(QUEUED)
  schedule   Schedule? @relation(fields: [scheduleId], references: [id], onDelete: SetNull)
  scheduleId String?
  error      String?
  request    Json?
  result     Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([accountId])
}
