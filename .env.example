# ----------------------------------------------------------------------------
# Local development environment.
# Copy this file to `.env` (npm scripts and Next.js auto-load `.env`).
# ----------------------------------------------------------------------------

# Postgres connection used by Next.js / Prisma (host -> docker-published port).
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/scheduler?schema=public"

# Credentials the docker-compose `db` service is created with. Keep in sync
# with DATABASE_URL above.
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=scheduler

# URL of the Python CP-SAT solver service (the `solver` docker-compose service).
SOLVER_URL="http://localhost:8000"

# Max seconds the CP-SAT solver may spend per solve before returning its best
# result so far. Lower = snappier UI, higher = better-optimized schedules.
SOLVER_TIME_LIMIT_SECONDS=15
